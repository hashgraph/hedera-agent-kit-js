{
  "name": "create-hedera-agent",
  "version": "0.2.0",
  "description": "Scaffold a Next.js chatbot wired with Hedera Agent Kit (Vercel AI SDK or LangChain).",
  "bin": {
    "create-hedera-agent": "dist/index.js"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "files": [
    "dist",
    "template",
    "runtime-variants"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsup index.ts --format cjs --dts --sourcemap --clean",
    "dev": "tsx watch index.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "execa": "^8.0.1",
    "fs-extra": "^11.3.4",
    "kolorist": "^1.8.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.19.17",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}