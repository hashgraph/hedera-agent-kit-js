{
  "name": "@hashgraph/hedera-agent-kit-langchain",
  "version": "1.0.0",
  "description": "LangChain integration for Hedera Agent Kit.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "format": "pnpm format:check",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "lint": "pnpm lint:check",
    "lint:check": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:unit": "echo 'No tests for @hashgraph/hedera-agent-kit-langchain (unit)'",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Hashgraph",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashgraph/hedera-agent-kit-js.git",
    "directory": "packages/langchain"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "@hashgraph/hedera-agent-kit": "workspace:*",
    "@langchain/core": "1.1.24",
    "@langchain/mcp-adapters": "1.1.3",
    "@modelcontextprotocol/sdk": "1.27.1",
    "langchain": "1.2.24",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@hashgraph/sdk": ">=2.81.0"
  },
  "devDependencies": {
    "@hashgraph/hedera-agent-kit-tests": "workspace:*",
    "@hashgraph/sdk": "2.81.0",
    "@langchain/openai": "1.2.7",
    "dotenv": "17.2.1",
    "tsup": "8.5.0",
    "typescript": "5.8.3",
    "vitest": "4.0.16"
  }
}
