{
  "name": "@hashgraph/hedera-agent-kit-core-contracts",
  "private": true,
  "description": "Internal Hardhat project for ERC20/ERC721 factory contracts used by @hashgraph/hedera-agent-kit.",
  "scripts": {
    "test": "hardhat test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,md,sol}\" --write",
    "format:check": "prettier \"**/*.{ts,tsx,js,jsx,json,md,sol}\" --check",
    "deploy:mainnet": "hardhat ignition deploy ignition/modules/deploy-factory.ts --network hederaMainnet",
    "deploy:testnet": "hardhat ignition deploy ignition/modules/deploy-factory.ts --network hederaTestnet",
    "deploy:previewnet": "hardhat ignition deploy ignition/modules/deploy-factory.ts --network hederaPreviewnet",
    "deploy:all": "pnpm deploy:mainnet & pnpm deploy:testnet & pnpm deploy:previewnet & wait"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "7.0.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "dotenv": "17.4.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "hardhat": "3.3.0",
    "prettier": "3.8.2",
    "prettier-plugin-solidity": "2.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1"
  }
}
