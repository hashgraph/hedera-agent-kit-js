# Operator key used by Hardhat. Must be a raw hex ECDSA secp256k1 key (0x + 64 hex chars).
HEDERA_PRIVATE_KEY=

# Override the JSON-RPC and mirror node URLs to deploy against a different endpoint.
# Leave empty to use the defaults below.
HEDERA_JSON_RPC_RELAY_URL=    # default: http://127.0.0.1:37546
HEDERA_MIRROR_NODE_REST_URL=  # default: http://127.0.0.1:38081/api/v1
