{
  "name": "@hashgraph/hedera-agent-kit",
  "version": "4.0.0",
  "description": "Core package for building agents that interact with the Hedera network.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/esm/plugins.d.mts",
        "default": "./dist/esm/plugins.mjs"
      },
      "require": {
        "types": "./dist/cjs/plugins.d.ts",
        "default": "./dist/cjs/plugins.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "format": "pnpm format:check",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "lint": "pnpm lint:check",
    "lint:check": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "echo 'No e2e tests for @hashgraph/hedera-agent-kit (core)'"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Hashgraph",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashgraph/hedera-agent-kit-js.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*"
  ],
  "dependencies": {
    "bignumber.js": "9.3.1",
    "ethers": "6.15.0",
    "long": "5.3.2",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.24.6"
  },
  "peerDependencies": {
    "@hashgraph/sdk": ">=2.80.0"
  },
  "devDependencies": {
    "@hashgraph/hedera-agent-kit-tests": "workspace:*",
    "@hashgraph/sdk": "2.80.0",
    "tsup": "8.5.0",
    "typescript": "5.8.3",
    "vitest": "4.0.16"
  }
}
