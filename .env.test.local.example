### Hedera credentials (required on every network)
# HEDERA_NETWORK - Which Hedera network the tests target
# HEDERA_ACCOUNT_ID - Operator account ID used to sign and pay for transactions
# HEDERA_PRIVATE_KEY - Operator private key matching HEDERA_ACCOUNT_ID. Must be a hex encoded ECDSA secp256k1 key (0x + 64 hex chars) to support EVM tooling.
#
# Solo defaults work out of the box. On testnet, paste your portal account ID and hex encoded ECDSA
# secp256k1 key (0x + 64 hex chars) in place of the Solo values below.
#
# Reference values per network:
#
# +------------+-----------------+----------------------------------------------------------------------+
# | Network    | Account ID      | Private key                                                          |
# +------------+-----------------+----------------------------------------------------------------------+
# | local-node | 0.0.1002        | 0x105d050185ccb907fba04dd92d8de9e32c18305e097ab41dadda21489a211524   |
# | testnet    | Your account ID | Your ECDSA key                                                       |
# +------------+-----------------+----------------------------------------------------------------------+
HEDERA_NETWORK=local-node
HEDERA_ACCOUNT_ID=0.0.1002 # Solo default account; CI sets this automatically
HEDERA_PRIVATE_KEY=0x105d050185ccb907fba04dd92d8de9e32c18305e097ab41dadda21489a211524 # Solo default ECDSA key; required by pnpm deploy:solo

### LLM credentials (required for e2e and agent-driven integration tests)
# OPENAI_API_KEY - API key for the chosen provider; substitute ANTHROPIC_API_KEY or GROQ_API_KEY when E2E_LLM_PROVIDER differs
# E2E_LLM_PROVIDER - Which LLM provider drives the agent
# E2E_LLM_MODEL - Model identifier passed to the provider
#
# Pick one row from the table and set the matching key. Create the API key in the
# provider's dashboard (e.g. https://platform.openai.com/api-keys for OpenAI).
#
# Reference values per provider:
#
# +-----------+-----------------------+---------------------------+
# | Provider  | Env var to set        | Example model             |
# +-----------+-----------------------+---------------------------+
# | openai    | OPENAI_API_KEY        | gpt-4o-mini               |
# | anthropic | ANTHROPIC_API_KEY     | claude-haiku-4-5          |
# +-----------+-----------------------+---------------------------+
OPENAI_API_KEY=sk-...
E2E_LLM_PROVIDER=openai
E2E_LLM_MODEL=gpt-4o-mini
