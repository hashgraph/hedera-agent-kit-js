# --- Core (required on every network) ---
HEDERA_NETWORK="local-node" # local-node (Solo) | testnet
HEDERA_ACCOUNT_ID="0.0.1002" # Solo default operator. Use your portal account ID when HEDERA_NETWORK=testnet
HEDERA_PRIVATE_KEY="0x105d050185ccb907fba04dd92d8de9e32c18305e097ab41dadda21489a211524" # Solo default operator key. Use your DER private key when HEDERA_NETWORK=testnet

# --- EVM / contract tests (required for ERC20/ERC721 tests on Solo) ---
# HEDERA_ECDSA_PRIVATE_KEY="0x105d050185ccb907fba04dd92d8de9e32c18305e097ab41dadda21489a211524" # Solo default EVM signer; required by pnpm deploy:solo
# HEDERA_ERC20_FACTORY_ADDRESS="0.0." # Populated by pnpm deploy:solo; CI sets this automatically
# HEDERA_ERC721_FACTORY_ADDRESS="0.0." # Populated by pnpm deploy:solo; CI sets this automatically

OPENAI_API_KEY="sk-..." # Create an OpenAI key at https://platform.openai.com/api-keys
E2E_LLM_PROVIDER="openai" # openai | anthropic | groq
E2E_LLM_MODEL="gpt-4o-mini" # any openai/anthropic/groq model
