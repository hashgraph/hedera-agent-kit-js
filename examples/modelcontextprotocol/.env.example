HEDERA_OPERATOR_ID="0.0.???"
HEDERA_OPERATOR_KEY="303..." # ECDSA DER encoded private key

# Required only for EVM token tools (CREATE_ERC20_TOOL, CREATE_ERC721_TOOL, MINT_ERC721_TOOL,
# TRANSFER_ERC20_TOOL, TRANSFER_ERC721_TOOL). Hedera contract ID of the deployed factory.
# To deploy your own factory contracts on any Hedera network, see the
# `packages/core-contracts` package and its README for instructions. EVM tools also require
# a hex encoded ECDSA (secp256k1) operator key. ED25519 keys are rejected upfront.
# HEDERA_ERC20_FACTORY_ADDRESS=0.0.6471814
# HEDERA_ERC721_FACTORY_ADDRESS=0.0.6510666
